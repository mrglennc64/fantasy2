__pycache__/
*.pyc
.venv/
.env
credentials.json
*.log
.DS_Store
web/dist/
# runtime state — the accuracy record is owned by whichever host runs the
# cron (kv8); committing it would fight the daily writes on git pull.
data/predictions_log.csv
data/predictions_log.*.bak
data/pick6_entries.csv
data/pick6_entries.*.bak
data/boards/*_scored.json
data/slates/
data/archive-pre-2026-07-08/
# Serving-time feature snapshots, written once per date alongside the board.
data/features/
# Learned constants. params.json is written by the refits ON THE HOST and must
# NOT be tracked: cron_daily.sh runs `git reset --hard origin/main` every half
# hour, so a tracked file would be reverted within the hour of being promoted.
# data/params.pinned.json is deliberately NOT ignored — being tracked is what
# makes a human pin survive that same reset and outrank the learned file.
data/params.json
data/params.json.tmp
data/params_history/
